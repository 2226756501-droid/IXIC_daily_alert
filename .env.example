# 邮箱配置（用于发送 NASDAQ 日报）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_smtp_authorization_code
NOTIFY_EMAIL=receiver@example.com

# DeepSeek API（用于 AI 分析）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 标的配置（默认 NASDAQ ^IXIC，黄金 GC=F）
NASDAQ_SYMBOL=^IXIC
GOLD_SYMBOL=GC=F
CNY_SYMBOL=CNY=X

# 黄金预警 Z-score 阈值（默认 2.0）
GOLD_ALERT_Z=2.0

